#!/bin/sh
# ┌─────────────────────────────────────────────────────────────────┐
# │  ani-stream                                                     │
# │  Stream anime from your terminal                                │
# │                                                                 │
# └─────────────────────────────────────────────────────────────────┘

VERSION="3.1.1"

# ─── AllAnime backend ─────────────────────────────────────────────
# FIX: switched to Chromium UA — AllAnime now rejects Firefox UA strings
AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
AA_REFR="https://allmanga.to"
AA_BASE="allanime.day"
AA_API="https://api.${AA_BASE}"

# ─── Runtime defaults ─────────────────────────────────────────────
mode="sub"
quality="best"
download_dir="${ANI_STREAM_DOWNLOAD_DIR:-$HOME/Downloads/anime}"
no_detach=0
exit_after_play=0
use_rofi=0
skip_intro=0
skip_title=""
log_ep=1
id=""
title=""
ep_no=""
ep_list=""
episode=""
links=""
replay=""
subs_flag=""
refr_flag=""
subtitle=""
m3u8_refr=""
resp=""
cache_dir=""
range=""
provider_id=""
provider_name=""
allanime_title=""

# ─── History / config paths ───────────────────────────────────────
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/ani-stream"
histfile="${state_dir}/history"
mkdir -p "$state_dir"
[ -f "$histfile" ] || touch "$histfile"

# ─── Colors ───────────────────────────────────────────────────────
if [ -t 1 ]; then
    R='\033[0m'   BD='\033[1m'
    C1='\033[38;5;141m' # Purple
    C2='\033[38;5;111m' # Sky Blue
    C3='\033[38;5;215m' # Orange
    C4='\033[38;5;120m' # Green
    C5='\033[38;5;203m' # Red
    C6='\033[38;5;246m' # Gray
    C7='\033[38;5;159m' # Cyan
else
    R='' BD='' C1='' C2='' C3='' C4='' C5='' C6='' C7=''
fi

# ─── Logging ──────────────────────────────────────────────────────
_log() { printf "%b\n" "$*" >&2; }
ok()   { _log " ${C4}✔${R}  $*"; }
info() { _log " ${C2}➜${R}  $*"; }
warn() { _log " ${C3}⚠${R}  $*"; }
err()  { _log " ${C5}✘${R}  $*"; }
die()  { err "$*"; exit 1; }

# ─── Dependency check ─────────────────────────────────────────────
dep_check() {
    for d; do
        command -v "$d" >/dev/null 2>&1 && continue
        err "Missing required tool: $d"
        case "$d" in
            mpv)    err "Install via: sudo apt install mpv (Debian) / brew install mpv (macOS) / pkg install mpv (Termux)" ;;
            fzf)    err "Install via: sudo apt install fzf (Debian) / brew install fzf (macOS) / pkg install fzf (Termux)" ;;
            curl)   err "Install via: sudo apt install curl (Debian) / brew install curl (macOS)" ;;
            yt-dlp) err "Install via: pip install yt-dlp" ;;
            *)      err "Please install '$d' using your package manager." ;;
        esac
        exit 1
    done
}

# ─── Update check ─────────────────────────────────────────────────
check_update() {
    _repo="https://raw.githubusercontent.com/aliabdoxd27-source/ani-stream/main/ani-stream"
    _current_script=$(readlink -f "$0")
    info "Checking for updates..."
    _remote_ver=$(curl -sL "$_repo" | grep '^VERSION="' | cut -d'"' -f2)
    if [ -z "$_remote_ver" ]; then
        die "Could not fetch version info. check your connection."
    fi
    if [ "$_remote_ver" != "$VERSION" ]; then
        info "New version available: $_remote_ver (current: $VERSION)"
        printf "${C7}Update now? [Y/n] ${R}"
        read -r _ans
        case "${_ans:-y}" in
            y|Y|yes)
                info "Downloading update..."
                curl -L "$_repo" -o "$_current_script"
                chmod +x "$_current_script"
                ok "Updated to $_remote_ver! Run ani-stream again."
                exit 0 ;;
            *) ok "Update skipped." ;;
        esac
    else
        ok "You are on the latest version ($VERSION)."
    fi
    exit 0
}

# ─── Platform / player detection ──────────────────────────────────
detect_player() {
    if [ -n "${ANI_STREAM_PLAYER:-}" ]; then printf '%s' "$ANI_STREAM_PLAYER"; return; fi
    case "$(uname -s)" in
        Darwin)
            [ -e "/Applications/IINA.app/Contents/MacOS/iina-cli" ] \
                && printf '%s' "/Applications/IINA.app/Contents/MacOS/iina-cli" \
                || printf '%s' "iina"
            ;;
        Linux)
            if [ -d "/data/data/com.termux" ] || [ -n "${TERMUX_VERSION:-}" ]; then
                printf '%s' "android_mpv"; return
            fi
            if command -v flatpak >/dev/null 2>&1 && \
               flatpak info io.mpv.Mpv >/dev/null 2>&1; then
                printf '%s' "flatpak_mpv"; return
            fi
            printf '%s' "mpv"
            ;;
        *)  printf '%s' "mpv" ;;
    esac
}

# ─── Launcher (fzf / rofi / plain numbered) ───────────────────────
launcher() {
    if [ "$use_rofi" = "1" ]; then
        rofi "$2" -sort -dmenu -i -width 1500 -p "$1"
        return
    fi
    if command -v fzf >/dev/null 2>&1; then
        _fzf_multi=""
        [ "$2" = "-m" ] && _fzf_multi="--multi"
        fzf $_fzf_multi --reverse --cycle \
            --prompt " $1 › " \
            --pointer "▶" --marker "◆" \
            --color="fg:#c0caf5,bg:-1,hl:#bb9af7" \
            --color="fg+:#c0caf5,bg+:#292e42,hl+:#7dcfff" \
            --color="info:#7aa2f7,prompt:#7dcfff,pointer:#f7768e" \
            --color="marker:#9ece6a,spinner:#9ece6a,header:#bb9af7" \
            --border=rounded --border-label=" ani-stream " \
            --border-label-pos=3 \
            --height=~60%
        return
    fi
    _n=0
    _items=""
    while IFS= read -r _line; do
        _n=$((_n+1))
        printf "  ${C2}%3d${R}  %s\n" "$_n" "$_line" >&2
        _items="${_items}${_line}\n"
    done
    printf "${C7}  %s [1-%d]: ${R}" "$1" "$_n" >&2
    read -r _pick </dev/tty
    printf '%b' "$_items" | sed -n "${_pick}p"
}

nth() {
    _stdin=$(cat -)
    [ -z "$_stdin" ] && return 1
    _lc=$(printf '%s\n' "$_stdin" | wc -l | tr -d '[:space:]')
    [ "$_lc" -eq 1 ] && printf '%s' "$_stdin" | cut -f2,3 && return 0
    _prompt="$1"; _mf=""
    [ $# -ne 1 ] && shift && _mf="$1"
    _line=$(printf '%s' "$_stdin" | cut -f1,3 | tr '\t' ' ' \
            | launcher "$_prompt" "$_mf" | cut -d' ' -f1)
    [ -z "$_line" ] && exit 1
    printf '%s' "$_stdin" | grep -E "^${_line}($|[[:space:]])" | cut -f2,3
}

# ═══════════════════════════════════════════════════════════════════
#  AllAnime — search
#  FIX: switched from GET (--data-urlencode) to POST (JSON body)
#       AllAnime API now requires POST with Content-Type: application/json
# ═══════════════════════════════════════════════════════════════════
search_anime() {
    # Sanitize input for JSON: escape backslashes and double quotes
    _safe_query=$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g')

    _sgql='query( $search: SearchInput $limit: Int $page: Int $translationType: VaildTranslationTypeEnumType $countryOrigin: VaildCountryOriginEnumType ) { shows( search: $search limit: $limit page: $page translationType: $translationType countryOrigin: $countryOrigin ) { edges { _id name availableEpisodes __typename } }}'

    curl -e "$AA_REFR" -s \
        -H "Content-Type: application/json" \
        -X POST "${AA_API}/api" \
        --data "{\"variables\":{\"search\":{\"allowAdult\":false,\"allowUnknown\":false,\"query\":\"$_safe_query\"},\"limit\":40,\"page\":1,\"translationType\":\"$mode\",\"countryOrigin\":\"ALL\"},\"query\":\"$_sgql\"}" \
        -A "$AGENT" \
    | sed 's|Show|\
|g' \
    | sed -nE "s|.*_id\":\"([^\"]*)\",\"name\":\"(.+)\",.*${mode}\":([1-9][^,]*).*|\1\t\2 (\3 ep)|p" \
    | sed 's/\\"//g'
}

# ═══════════════════════════════════════════════════════════════════
#  AllAnime — episode list
#  FIX: switched from GET to POST
# ═══════════════════════════════════════════════════════════════════
episodes_list() {
    _elgql='query ($showId: String!) { show( _id: $showId ) { _id availableEpisodesDetail }}'

    curl -e "$AA_REFR" -s \
        -H "Content-Type: application/json" \
        -X POST "${AA_API}/api" \
        --data "{\"variables\":{\"showId\":\"$1\"},\"query\":\"$_elgql\"}" \
        -A "$AGENT" \
    | sed -nE "s|.*${mode}\":\[([0-9.\",]*)\].*|\1|p" \
    | sed 's|,|\
|g; s|"||g' \
    | sort -n -k1
}

