# ═══════════════════════════════════════════════════════════════════
#  Entry point
# ═══════════════════════════════════════════════════════════════════
dep_check curl sed grep awk

player_function="$(detect_player)"
_default_player="$player_function"
_cli_ep=""
_cli_search=""
_do_continue=0
_do_delete=0

while [ $# -gt 0 ]; do
    case "$1" in
        -s|--search)             _cli_search="$2";           shift 2 ;;
        -e|--episode|-r|--range) _cli_ep="$2";               shift 2 ;;
        -c|--continue)           _do_continue=1;             shift ;;
        -d|--download)           player_function="download"; shift ;;
        --download-dir)          download_dir="$2";          shift 2 ;;
        -q|--quality)            quality="$2";               shift 2 ;;
        --dubbed|--dub)          mode="dub";                 shift ;;
        --sub)                   mode="sub";                 shift ;;
        --player)                player_function="$2"; _default_player="$2"; shift 2 ;;
        --no-detach)             no_detach=1;                shift ;;
        --exit-after-play)       exit_after_play=1;          shift ;;
        --skip-intro|--skip)     skip_intro=1;               shift ;;
        --skip-title)            skip_title="$2";            shift 2 ;;
        --rofi)                  use_rofi=1;                 shift ;;
        --delete-history|-D)     _do_delete=1;               shift ;;
        --update)                check_update ;;
        -v|--version)            printf 'ani-stream v%s\n' "$VERSION"; exit 0 ;;
        -h|--help)               usage; exit 0 ;;
        --)                      shift; _cli_search="$*"; break ;;
        -*)                      die "Unknown flag: $1  (try --help)" ;;
        *)                       _cli_search="${_cli_search:+$_cli_search }$1"; shift ;;
    esac
done

# Delete history
if [ "$_do_delete" = "1" ]; then
    printf '' > "$histfile"
    ok "Watch history cleared."
    exit 0
fi

# Non-interactive: query on CLI
if [ -n "$_cli_search" ]; then
    dep_check fzf
    info "Searching: ${_cli_search}  [${mode}]"
    _results=$(search_anime "$_cli_search")
    [ -z "$_results" ] && die "No results for: ${_cli_search}"

    _indexed=$(printf '%s' "$_results" | awk -F'\t' '{printf "%d\t%s\t%s\n", NR, $1, $2}')
    _sel=$(printf '%s' "$_indexed" | nth "Anime")
    [ -z "$_sel" ] && exit 1
    id=$(printf '%s' "$_sel" | cut -f1)
    title=$(printf '%s' "$_sel" | cut -f2)
    allanime_title="${title} "
    ok "Selected: ${title}"

    ep_list=$(episodes_list "$id")
    [ -z "$ep_list" ] && die "No ${mode} episodes found. Try --sub or --dubbed."

    if [ -n "$_cli_ep" ]; then
        ep_no="$_cli_ep"
    else
        _epcount=$(printf '%s\n' "$ep_list" | wc -l | tr -d '[:space:]')
        if [ "$_epcount" -eq 1 ]; then
            ep_no=$(printf '%s' "$ep_list")
        else
            _idxeps=$(printf '%s\n' "$ep_list" | awk '{printf "%d\tEp%s\tEpisode %s\n", NR, $0, $0}')
            _epsel=$(printf '%s' "$_idxeps" | nth "Episode")
            [ -z "$_epsel" ] && exit 1
            ep_no=$(printf '%s' "$_epsel" | cut -f1 | sed 's/^Ep//')
        fi
    fi
    play
    exit 0
fi

# Non-interactive: continue
if [ "$_do_continue" = "1" ]; then
    dep_check fzf
    [ ! -s "$histfile" ] && die "No history found."
    _hix=$(awk -F'\t' '{printf "%d\t%s\t%s  ep %s\n", NR, $2, $3, $1}' "$histfile")
    _hsel=$(printf '%s' "$_hix" | nth "Resume")
    [ -z "$_hsel" ] && exit 1
    id=$(printf '%s' "$_hsel" | cut -f1)
    _rest=$(printf '%s' "$_hsel" | cut -f2)
    title=$(printf '%s' "$_rest" | sed 's/  ep.*//')
    _last_ep=$(printf '%s' "$_rest" | grep -oE 'ep [^ ]*' | cut -d' ' -f2)
    allanime_title="${title} "
    ep_list=$(episodes_list "$id")
    [ -z "$ep_list" ] && die "Could not load episodes."
    ep_no=$(printf '%s' "$ep_list" | grep -A1 "^${_last_ep}$" | tail -n1)
    [ -z "$ep_no" ] && ep_no="$_last_ep"
    [ -n "$_cli_ep" ] && ep_no="$_cli_ep"
    ok "Resuming: ${title} → Episode ${ep_no}  [${mode}]"
    play
    exit 0
fi

# Interactive
dep_check fzf
main_menu
