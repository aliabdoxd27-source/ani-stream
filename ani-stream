# ═══════════════════════════════════════════════════════════════════
#  AllAnime — resolve embed → direct video URL
# ═══════════════════════════════════════════════════════════════════
get_links() {
    _response="$(curl -e "$AA_REFR" -s "https://${AA_BASE}$*" -A "$AGENT")"

    _ep_link="$(printf '%s' "$_response" \
        | sed 's|},{|\
|g' \
        | sed -nE \
            's|.*link":"([^"]*)".*"resolutionStr":"([^"]*)".*|\2 >\1|p
             s|.*hls","url":"([^"]*)".*"hardsub_lang":"en-US".*|\1|p')"

    case "$_ep_link" in
        *repackager.wixmp.com*)
            _extract=$(printf '%s' "$_ep_link" | cut -d'>' -f2 \
                | sed 's|repackager.wixmp.com/||g;s|\.urlset.*||g')
            for _j in $(printf '%s' "$_ep_link" \
                    | sed -nE 's|.*/,([^/]*),/mp4.*|\1|p' \
                    | sed 's|,|\
|g'); do
                printf '%s >%s\n' "$_j" "$_extract" | sed "s|,[^/]*|${_j}|g"
            done | sort -nr
            ;;
        *master.m3u8*)
            m3u8_refr=$(printf '%s' "$_response" \
                | sed -nE 's|.*Referer":"([^"]*)".*|\1|p')
            printf '%s\n' "m3u8_refr >$m3u8_refr" > "${cache_dir}/m3u8_refr"
            _extract=$(printf '%s' "$_ep_link" | head -1 | cut -d'>' -f2)
            _relative=$(printf '%s' "$_extract" | sed 's|[^/]*$||')
            _m3u8="$(curl -e "$m3u8_refr" -s "$_extract" -A "$AGENT")"
            printf '%s' "$_m3u8" | grep -q "EXTM3U" && \
                printf '%s' "$_m3u8" \
                | sed 's|^#EXT-X-STREAM.*x||g; s|,.*|p|g; /^#/d; $!N; s|\n| >|;/EXT-X-I-FRAME/d' \
                | sed "s|>|cc>${_relative}|g" | sort -nr
            printf '%s' "$_response" \
                | sed -nE 's|.*"subtitles":\[\{"lang":"en","label":"English","default":"default","src":"([^"]*)".*|subtitle >\1|p' \
                > "${cache_dir}/suburl"
            ;;
        *)
            [ -n "$_ep_link" ] && printf '%s\n' "$_ep_link"
            ;;
    esac

    printf '%s' "$*" | grep -q "tools.fast4speed.rsvp" && printf '%s\n' "Yt >$*"

    # ── Status line — distinct from ani-cli ───────────────────────
    printf "${C6}  [ %s loaded ]${R}\n" "$provider_name" >&2
}

generate_link() {
    case $1 in
        1) provider_init "mirror-1" "/Default :/p"  ;;
        2) provider_init "mirror-2" "/Yt-mp4 :/p"   ;;
        3) provider_init "mirror-3" "/S-mp4 :/p"    ;;
        *)  provider_init "mirror-4" "/Luf-Mp4 :/p" ;;
    esac
    [ -n "$provider_id" ] && get_links "$provider_id"
}

# ═══════════════════════════════════════════════════════════════════
#  AllAnime — collect all source URLs for one episode
#  FIX: switched from GET to POST
# ═══════════════════════════════════════════════════════════════════
get_episode_url() {
    _eegql='query ($showId: String!, $translationType: VaildTranslationTypeEnumType!, $episodeString: String!) { episode( showId: $showId translationType: $translationType episodeString: $episodeString ) { episodeString sourceUrls }}'

    resp=$(curl -e "$AA_REFR" -s \
        -H "Content-Type: application/json" \
        -X POST "${AA_API}/api" \
        --data "{\"variables\":{\"showId\":\"$id\",\"translationType\":\"$mode\",\"episodeString\":\"$ep_no\"},\"query\":\"$_eegql\"}" \
        -A "$AGENT" \
        | tr '{}' '\n' \
        | sed 's|\\u002F|/|g;s|\\||g' \
        | sed -nE 's|.*sourceUrl":"--([^"]*)".*sourceName":"([^"]*)".*|\2 :\1|p')

    cache_dir="$(mktemp -d)"
    for _p in 1 2 3 4; do
        generate_link "$_p" > "${cache_dir}/${_p}" &
    done
    wait
    links=$(cat "${cache_dir}/"* 2>/dev/null | sort -g -r -s)
    rm -rf "$cache_dir"
    select_quality "$quality"

    if printf '%s' "$ep_list" | grep -q "^${ep_no}$"; then
        [ -z "$episode" ] && die "Episode found but no valid sources."
    else
        [ -z "$episode" ] && die "Episode not yet released."
    fi
}

# ─── Quality selection ────────────────────────────────────────────
select_quality() {
    case "$player_function" in
        android*|*vlc*|iSH*)
            links=$(printf '%s' "$links" | sed '/cc>/d;/subtitle >/d;/m3u8_refr >/d') ;;
    esac
    case "$player_function" in
        android*|iSH*)
            links=$(printf '%s' "$links" | sed '/Yt >/d') ;;
    esac

    case "$1" in
        best)  _result=$(printf '%s' "$links" | head -n1) ;;
        worst) _result=$(printf '%s' "$links" | grep -E '^[0-9]{3,4}' | tail -n1) ;;
        *)     _result=$(printf '%s' "$links" | grep -m1 "$1") ;;
    esac
    [ -z "$_result" ] && \
        warn "Quality '$1' not available, using best" && \
        _result=$(printf '%s' "$links" | head -n1)

    subs_flag=""; refr_flag=""
    if printf '%s' "$_result" | grep -q "cc>"; then
        subtitle=$(printf '%s' "$links" | sed -nE 's|subtitle >(.*)|\1|p')
        m3u8_refr=$(printf '%s' "$links" | sed -nE 's|m3u8_refr >(.*)|\1|p')
        [ -n "$subtitle"  ] && subs_flag="--sub-file=$subtitle"
        [ -n "$m3u8_refr" ] && refr_flag="--referrer=$m3u8_refr"
    fi
    printf '%s' "$_result" | grep -q "tools.fast4speed.rsvp" && \
        refr_flag="--referrer=$AA_REFR"

    episode=$(printf '%s' "$_result" | cut -d'>' -f2)
}

# ═══════════════════════════════════════════════════════════════════
#  History
# ═══════════════════════════════════════════════════════════════════
update_history() {
    if grep -q "	${id}	" "$histfile" 2>/dev/null; then
        sed -E "s|^[^	]+	${id}	[^	]+$|${ep_no}	${id}	${title}|" \
            "$histfile" > "${histfile}.new"
    else
        cp "$histfile" "${histfile}.new"
        printf '%s\t%s\t%s\n' "$ep_no" "$id" "$title" >> "${histfile}.new"
    fi
    mv "${histfile}.new" "$histfile"
}

# ═══════════════════════════════════════════════════════════════════
#  Download
# ═══════════════════════════════════════════════════════════════════
do_download() {
    mkdir -p "$download_dir"
    [ -n "$subtitle" ] && curl -s "$subtitle" -o "${download_dir}/$2.vtt"
    case $1 in
        *m3u8*)
            if command -v yt-dlp >/dev/null 2>&1; then
                yt-dlp --referer "${m3u8_refr:-$AA_REFR}" "$1" \
                    --no-skip-unavailable-fragments --fragment-retries infinite \
                    -N 16 -o "${download_dir}/$2.%(ext)s"
            elif command -v ffmpeg >/dev/null 2>&1; then
                ffmpeg -extension_picky 0 -referer "${m3u8_refr:-$AA_REFR}" \
                    -loglevel error -stats -i "$1" -c copy "${download_dir}/$2.mp4"
            else
                die "Need yt-dlp or ffmpeg to download HLS streams"
            fi ;;
        *)
            if command -v aria2c >/dev/null 2>&1; then
                aria2c --referer="$AA_REFR" --enable-rpc=false \
                    --check-certificate=false --continue \
                    --summary-interval=0 -x 16 -s 16 \
                    "$1" --dir="$download_dir" -o "$2.mp4" --download-result=hide
            else
                curl -L --progress-bar -H "Referer: $AA_REFR" \
                    -o "${download_dir}/$2.mp4" "$1"
            fi ;;
    esac
    ok "Saved → ${download_dir}/$2.mp4"
}

# ═══════════════════════════════════════════════════════════════════
#  Play one episode
# ═══════════════════════════════════════════════════════════════════
play_episode() {
    [ -z "$episode" ] && get_episode_url

    [ "$log_ep" = "1" ] && command -v logger >/dev/null 2>&1 && \
        logger -t ani-stream "${allanime_title}ep${ep_no}"

    skip_flag=""
    [ "$skip_intro" = "1" ] && command -v ani-skip >/dev/null 2>&1 && \
        skip_flag="$(ani-skip -q "${skip_title:-$title}" -e "$ep_no")"

    # shellcheck disable=SC2086
    case "$player_function" in
        debug)
            printf '\n%bAll sources:%b\n%s\n\n%bSelected:%b\n%s\n' \
                "$BD" "$R" "$links" "$BD" "$R" "$episode"
            ;;
        mpv*)
            if [ "$no_detach" = "0" ]; then
                nohup $player_function \
                    --save-position-on-quit \
                    ${skip_flag:+$skip_flag} \
                    --force-media-title="${allanime_title}Episode ${ep_no}" \
                    "$episode" \
                    ${subs_flag:+$subs_flag} \
                    ${refr_flag:+$refr_flag} \
                    >/dev/null 2>&1 &
            else
                $player_function \
                    --save-position-on-quit \
                    ${skip_flag:+$skip_flag} \
                    ${subs_flag:+$subs_flag} \
                    ${refr_flag:+$refr_flag} \
                    --force-media-title="${allanime_title}Episode ${ep_no}" \
                    "$episode"
                _ec=$?
                [ "$exit_after_play" = "1" ] && [ -z "$range" ] && exit "$_ec"
            fi ;;
        android_mpv)
            nohup am start --user 0 \
                -a android.intent.action.VIEW \
                -d "$episode" \
                -n is.xyz.mpv/.MPVActivity \
                >/dev/null 2>&1 & ;;
        android_vlc)
            nohup am start --user 0 \
                -a android.intent.action.VIEW \
                -d "$episode" \
                -n org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity \
                -e "title" "${allanime_title}Episode ${ep_no}" \
                >/dev/null 2>&1 & ;;
        *iina*)
            [ -n "$subs_flag" ] && subs_flag="--mpv-${subs_flag#--}"
            [ -n "$refr_flag" ] && refr_flag="--mpv-${refr_flag#--}"
            if pgrep -f "IINA" >/dev/null 2>&1; then
                nohup $player_function --no-stdin \
                    --mpv-force-media-title="${allanime_title}Episode ${ep_no}" \
                    ${subs_flag:+$subs_flag} ${refr_flag:+$refr_flag} \
                    "$episode" >/dev/null 2>&1 &
            else
                nohup $player_function --no-stdin --keep-running \
                    --mpv-force-media-title="${allanime_title}Episode ${ep_no}" \
                    ${subs_flag:+$subs_flag} ${refr_flag:+$refr_flag} \
                    "$episode" >/dev/null 2>&1 &
            fi ;;
        flatpak_mpv)
            flatpak run io.mpv.Mpv \
                --force-media-title="${allanime_title}Episode ${ep_no}" \
                "$episode" \
                ${subs_flag:+$subs_flag} \
                ${refr_flag:+$refr_flag} \
                >/dev/null 2>&1 & ;;
        vlc*)
            nohup $player_function \
                --http-referrer="$AA_REFR" --play-and-exit \
                --meta-title="${allanime_title}Episode ${ep_no}" \
                "$episode" >/dev/null 2>&1 & ;;
        download)
            do_download "$episode" "${allanime_title}Episode_${ep_no}" ;;
        *)
            nohup $player_function "$episode" >/dev/null 2>&1 & ;;
    esac

    replay="$episode"
    unset episode
    update_history
    [ "$use_rofi" = "1" ] && wait
}

# ─── Episode range / batch play ───────────────────────────────────
play() {
    _start=$(printf '%s' "$ep_no" | grep -Eo '^(-1|[0-9]+(\.[0-9]+)?)')
    _end=$(printf '%s' "$ep_no" | grep -Eo '(-1|[0-9]+(\.[0-9]+)?)$')
    [ "$_start" = "-1" ] && ep_no=$(printf '%s' "$ep_list" | tail -n1) && unset _start
    { [ -z "${_end:-}" ] || [ "${_end:-}" = "${_start:-}" ]; } && unset _start _end
    [ "${_end:-}" = "-1" ] && _end=$(printf '%s' "$ep_list" | tail -n1)

    _lc=$(printf '%s\n' "$ep_no" | wc -l | tr -d '[:space:]')
    if [ "$_lc" != "1" ] || [ -n "${_start:-}" ]; then
        [ -z "${_start:-}" ] && _start=$(printf '%s\n' "$ep_no" | head -n1)
        [ -z "${_end:-}"   ] && _end=$(printf '%s\n' "$ep_no" | tail -n1)
        range=$(printf '%s\n' "$ep_list" | sed -nE "/^${_start}$/,/^${_end}$/p")
        [ -z "$range" ] && die "Invalid episode range"
        for _i in $range; do
            tput clear 2>/dev/null || printf '\033[2J\033[H'
            ep_no="$_i"
            info "Playing: ${allanime_title}Episode ${ep_no}  [${mode}]"
            [ "$_i" = "$_end" ] && unset range
            play_episode
        done
    else
        play_episode
    fi
    tput rc 2>/dev/null; tput ed 2>/dev/null; true
}

