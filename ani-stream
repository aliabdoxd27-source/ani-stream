# ═══════════════════════════════════════════════════════════════════
#  UI — main interactive loop
# ═══════════════════════════════════════════════════════════════════
show_status_bar() {
    _mc="$C2"; [ "$mode" = "dub" ] && _mc="$C3"
    printf '%b' "${C6}  player › ${C3}${player_function}${C6}   mode › ${_mc}${mode}${C6}   quality › ${C3}${quality}${R}\n\n"
}

after_episode_menu() {
    printf '\n'
    printf '%b' "  ${C1}${BD}╭──────────────── Navigation ────────────────╮${R}\n"
    printf '%b' "  ${C1}${BD}│${R}  ${C2}n${R}  next episode       ${C2}p${R}  previous    ${C1}${BD}│${R}\n"
    printf '%b' "  ${C1}${BD}│${R}  ${C2}r${R}  replay             ${C2}s${R}  pick ep     ${C1}${BD}│${R}\n"
    printf '%b' "  ${C1}${BD}│${R}  ${C2}a${R}  new search         ${C2}q${R}  quit        ${C1}${BD}│${R}\n"
    printf '%b' "  ${C1}${BD}╰────────────────────────────────────────────╯${R}\n"
    printf '\n'
    printf '%b' "  ${C7}action › ${R}"
    read -r _act </dev/tty
    _act="${_act:-n}"
    case "$_act" in
        n|N|next|"")
            _nxt=$(printf '%s' "$ep_list" | grep -A1 "^${ep_no}$" | tail -n1)
            if [ -z "$_nxt" ] || [ "$_nxt" = "$ep_no" ]; then
                warn "No next episode available."
            else
                ep_no="$_nxt"
            fi ;;
        p|P|prev*)
            _prv=$(printf '%s' "$ep_list" | grep -B1 "^${ep_no}$" | head -n1)
            if [ -z "$_prv" ] || [ "$_prv" = "$ep_no" ]; then
                warn "Already at the first episode."
            else
                ep_no="$_prv"
            fi ;;
        r|R|replay)
            episode="$replay" ;;
        s|S|select)
            _idxeps=$(printf '%s\n' "$ep_list" | \
                awk '{printf "%d\t%s\tEp %s\n", NR, $0, $0}')
            _epsel=$(printf '%s' "$_idxeps" | nth "Episode")
            [ -n "$_epsel" ] && ep_no=$(printf '%s' "$_epsel" | cut -f1) ;;
        a|A|search)
            main_menu; return ;;
        q|Q|quit|exit)
            printf '%b' "${C4}  bye!${R}\n"; exit 0 ;;
        [0-9]*)
            if printf '%s' "$ep_list" | grep -q "^${_act}$"; then
                ep_no="$_act"
            else
                warn "Episode ${_act} not in list."
            fi ;;
        *)  warn "Unknown action: ${_act}" ;;
    esac
}

watch_session() {
    while true; do
        tput sc 2>/dev/null || true
        printf '\n'
        printf '%b' "  ${C1}${BD}▶${R}  ${BD}${allanime_title}${R}${C6}  ep ${ep_no}  [${mode}]${R}\n"
        play
        after_episode_menu
    done
}

run_search() {
    printf '%b' "  ${C7}search › ${R}"
    read -r _q </dev/tty
    [ -z "$_q" ] && return

    info "Searching: ${_q}  [${mode}]"
    _results=$(search_anime "$_q")
    if [ -z "$_results" ]; then
        warn "No results for '${_q}'"
        [ "$mode" = "dub" ] && warn "Dub may not be available — try toggling mode with 'm'"
        return
    fi

    _indexed=$(printf '%s' "$_results" | awk -F'\t' '{printf "%d\t%s\t%s\n", NR, $1, $2}')
    _sel=$(printf '%s' "$_indexed" | nth "Anime")
    [ -z "$_sel" ] && return

    id=$(printf '%s' "$_sel" | cut -f1)
    title=$(printf '%s' "$_sel" | cut -f2)
    allanime_title="${title} "

    ok "Selected: ${title}"

    ep_list=$(episodes_list "$id")
    if [ -z "$ep_list" ]; then
        warn "No episodes found for this mode. Toggle with 'm' to switch sub/dub."
        return
    fi

    _epcount=$(printf '%s\n' "$ep_list" | wc -l | tr -d '[:space:]')
    info "${_epcount} episode(s) available  [${mode}]"

    if [ "$_epcount" -eq 1 ]; then
        ep_no=$(printf '%s' "$ep_list")
    elif [ -n "${_cli_ep:-}" ]; then
        ep_no="$_cli_ep"
        unset _cli_ep
    else
        _idxeps=$(printf '%s\n' "$ep_list" | awk '{printf "%d\tEp%s\tEpisode %s\n", NR, $0, $0}')
        _epsel=$(printf '%s' "$_idxeps" | nth "Episode")
        [ -z "$_epsel" ] && return
        ep_no=$(printf '%s' "$_epsel" | cut -f1 | sed 's/^Ep//')
    fi

    watch_session
}

show_history() {
    if [ ! -s "$histfile" ]; then warn "No watch history yet."; return; fi
    printf '\n%b' "  ${C1}${BD}─── Watch History ──────────────────────────────${R}\n"
    awk -F'\t' '{printf "    %2d.  %-42s  ep %s\n", NR, $3, $1}' "$histfile"
    printf '\n'
}

resume_history() {
    [ ! -s "$histfile" ] && warn "No history." && return
    _hix=$(awk -F'\t' '{printf "%d\t%s\t%s  ep %s\n", NR, $2, $3, $1}' "$histfile")
    _hsel=$(printf '%s' "$_hix" | nth "Resume")
    [ -z "$_hsel" ] && return

    id=$(printf '%s' "$_hsel" | cut -f1)
    _rest=$(printf '%s' "$_hsel" | cut -f2)
    title=$(printf '%s' "$_rest" | sed 's/  ep.*//')
    _last_ep=$(printf '%s' "$_rest" | grep -oE 'ep [^ ]*' | cut -d' ' -f2)
    allanime_title="${title} "

    ep_list=$(episodes_list "$id")
    [ -z "$ep_list" ] && warn "Could not load episodes." && return

    ep_no=$(printf '%s' "$ep_list" | grep -A1 "^${_last_ep}$" | tail -n1)
    [ -z "$ep_no" ] && ep_no="$_last_ep"

    ok "Resuming: ${title} → Episode ${ep_no}  [${mode}]"
    watch_session
}

# ═══════════════════════════════════════════════════════════════════
#  Main interactive menu
# ═══════════════════════════════════════════════════════════════════
main_menu() {
    clear 2>/dev/null || printf '\033[2J\033[H'
    banner
    while true; do
        show_status_bar
        printf '%b' "  ${C1}${BD}╭─────────────────── Menu ────────────────────╮${R}\n"
        printf '%b' "  ${C1}${BD}│${R}  ${C2}1${R}  search & watch      ${C2}2${R}  resume       ${C1}${BD}│${R}\n"
        printf '%b' "  ${C1}${BD}│${R}  ${C2}3${R}  history             ${C2}m${R}  sub/dub      ${C1}${BD}│${R}\n"
        printf '%b' "  ${C1}${BD}│${R}  ${C2}d${R}  download mode       ${C2}q${R}  quality      ${C1}${BD}│${R}\n"
        printf '%b' "  ${C1}${BD}│${R}  ${C2}p${R}  set player          ${C2}x${R}  exit         ${C1}${BD}│${R}\n"
        printf '%b' "  ${C1}${BD}╰─────────────────────────────────────────────╯${R}\n"
        printf '\n'
        printf '%b' "  ${C7}choice › ${R}"
        read -r _ch </dev/tty
        printf '\n'
        case "$_ch" in
            1|s|S) run_search ;;
            2|c|C) resume_history ;;
            3|h|H) show_history ;;
            m|M)
                [ "$mode" = "sub" ] && mode="dub" || mode="sub"
                ok "Mode → ${mode}" ;;
            d|D)
                if [ "$player_function" = "download" ]; then
                    player_function="$_default_player"
                    ok "Download mode OFF"
                else
                    _default_player="$player_function"
                    player_function="download"
                    ok "Download mode ON  (→ ${download_dir})"
                fi ;;
            q|Q)
                printf '%b' "  ${C7}quality (best/1080/720/480/360) › ${R}"
                read -r _qv </dev/tty
                [ -n "$_qv" ] && quality="$_qv" && ok "Quality → ${quality}" ;;
            p|P)
                printf '%b' "  ${C7}player (mpv/vlc/android_mpv/debug) › ${R}"
                read -r _pv </dev/tty
                [ -n "$_pv" ] && player_function="$_pv" && _default_player="$_pv" && ok "Player → ${player_function}" ;;
            x|X|exit|quit) printf '%b' "  ${C4}bye!${R}\n"; exit 0 ;;
            *) [ -n "$_ch" ] && warn "Unknown choice: ${_ch}" ;;
        esac
        printf '\n'
    done
}

